{
  "name": "open-acp-reasonix",
  "version": "0.52.0",
  "description": "ACP-native agent backend (Open-ACP-Reasonix): cache-first loop, OpenRouter + DeepSeek, MCP bridging.",
  "type": "module",
  "bin": {
    "reasonix": "dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "scripts/copy-tree-sitter-grammars.mjs",
    "README.md",
    "LICENSE"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsup && node scripts/copy-tree-sitter-grammars.mjs",
    "dev": "tsx src/cli/index.ts",
    "acp": "tsx src/cli/index.ts acp",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests",
    "format": "biome format --write src tests",
    "typecheck": "tsc --noEmit",
    "verify": "npm run lint && npm run typecheck && npm run test --silent",
    "prepare": "simple-git-hooks || true",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run build && npm run test"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run lint"
  },
  "keywords": [
    "acp",
    "agent-client-protocol",
    "agent",
    "llm",
    "openrouter",
    "deepseek",
    "tool-use",
    "prompt-cache",
    "mcp"
  ],
  "author": "esengine, fork by William Sandstrom",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "eventsource-parser": "^3.0.0",
    "iconv-lite": "^0.7.2",
    "ignore": "^7.0.5",
    "node-html-parser": "^7.1.0",
    "picomatch": "^4.0.4",
    "tiktoken": "^1.0.22",
    "undici": "^8.2.0",
    "web-tree-sitter": "^0.26.9",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@reasonix/core-utils": "workspace:*",
    "@types/node": "^22.9.0",
    "@types/picomatch": "^4.0.3",
    "@vitest/coverage-v8": "^2.1.5",
    "simple-git-hooks": "^2.13.1",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-typescript": "^0.23.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
